# ═══════════════════════════════════════════════════════
# HukukAI — Ortam Değişkenleri (Kopyala → .env.local)
# ═══════════════════════════════════════════════════════

# OpenAI (gerekli — chat için)
OPENAI_API_KEY=sk-your-openai-api-key

# Uygulama URL (prod: https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (zorunlu — 32+ karakter)
AUTH_SECRET=generate-with-npx-auth-secret

# Veritabanı — PostgreSQL (Vercel/Neon/Supabase)
# Neon (ücretsiz): https://neon.tech
# Supabase (ücretsiz): https://supabase.com
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── OAuth: Google ile Giriş ───
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Redirect URI: https://your-app.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=xxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=xxx

# ─── OAuth: Apple ile Giriş ───
# Apple Developer → Sign in with Apple → Keys
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Opsiyonel: Demo hesap (yoksa demo@hukukai.com / demo1234)
# AUTH_DEMO_EMAIL=
# AUTH_DEMO_PASSWORD=
