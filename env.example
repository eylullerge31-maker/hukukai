# OpenAI API Anahtarı
OPENAI_API_KEY=sk-your-openai-api-key-here

# Uygulama URL'i
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth (oturum) — AUTH_SECRET zorunlu
AUTH_SECRET=your-auth-secret-min-32-chars-long-random-string

# Opsiyonel: Demo giriş bilgileri (yoksa demo@hukukai.com / demo1234 kullanılır)
# AUTH_DEMO_EMAIL=demo@hukukai.com
# AUTH_DEMO_PASSWORD=demo1234

# Veritabanı — SQLite (geliştirme) veya PostgreSQL (üretim)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/hukukai"

# Eski / kullanılmayan
# NEXTAUTH_SECRET=...
# NEXTAUTH_URL=...
